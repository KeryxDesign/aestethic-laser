---
// Google Analytics (G-Y6RS2ZNDT8) caricato SOLO dopo consenso (Garante: cookie
// statistici = consenso preventivo). Scelta salvata in localStorage. Nessun
// contatto con Google prima di "Accetta".
const base = import.meta.env.BASE_URL;
const GA = "G-Y6RS2ZNDT8";
---

<div id="cookie-banner" class="ccb" role="dialog" aria-label="Consenso cookie">
  <p class="ccb__txt">
    Usiamo cookie di statistica (Google Analytics) per capire come viene usato il
    sito e migliorarlo. Sono facoltativi. <a href={`${base}/privacy`}>Privacy &amp; Cookie</a>
  </p>
  <div class="ccb__btns">
    <button type="button" id="cc-reject" class="ccb__btn ccb__btn--ghost">Rifiuta</button>
    <button type="button" id="cc-accept" class="ccb__btn ccb__btn--ok">Accetta</button>
  </div>
</div>

<script is:inline>
  (function () {
    var GA = "G-Y6RS2ZNDT8";
    var AW = "AW-18315282135"; // Google Ads: remarketing + contenitore conversioni
    function loadGA() {
      if (window.__gaLoaded) return;
      window.__gaLoaded = true;
      var s = document.createElement("script");
      s.async = true;
      s.src = "https://www.googletagmanager.com/gtag/js?id=" + GA;
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag("js", new Date());
      gtag("config", GA, { anonymize_ip: true });
      gtag("config", AW); // stesso gtag.js, nessun secondo caricamento
    }
    var banner = document.getElementById("cookie-banner");
    var choice = null;
    try { choice = localStorage.getItem("gb_consent"); } catch (e) {}
    if (choice === "granted") { loadGA(); return; }
    if (choice === "denied") { return; }
    if (banner) banner.classList.add("ccb--show");
    var acc = document.getElementById("cc-accept");
    var rej = document.getElementById("cc-reject");
    if (acc) acc.addEventListener("click", function () {
      try { localStorage.setItem("gb_consent", "granted"); } catch (e) {}
      if (banner) banner.classList.remove("ccb--show");
      loadGA();
    });
    if (rej) rej.addEventListener("click", function () {
      try { localStorage.setItem("gb_consent", "denied"); } catch (e) {}
      if (banner) banner.classList.remove("ccb--show");
    });
  })();
</script>

<script is:inline>
  // Tracciamento eventi GA4 per import conversioni in Google Ads.
  // Event delegation su document: un solo listener per i clic e uno per i submit,
  // cosi copre gli stessi link/form su tutte le pagine che includono Analytics.
  // No-op silenzioso se gtag non esiste (consenso cookie non concesso -> nessun errore).
  (function () {
    function track(name, params) {
      if (window.gtag) window.gtag("event", name, params || {});
    }

    // Submit di qualsiasi form.form (hero + cta). data-form-location distingue i due.
    document.addEventListener("submit", function (e) {
      var form = e.target && e.target.closest ? e.target.closest("form.form") : null;
      if (!form) return;
      var loc = form.getAttribute("data-form-location") || "unknown";
      track("lead_form_submit", { form_location: loc, transport_type: "beacon" });
    }, true);

    // Clic su link WhatsApp e telefono. capture:true per registrare prima della navigazione.
    document.addEventListener("click", function (e) {
      var t = e.target;
      if (!t || !t.closest) return;
      if (t.closest('a[href*="wa.me"]')) {
        track("click_whatsapp", { transport_type: "beacon" });
        return;
      }
      if (t.closest('a[href^="tel:"]')) {
        track("click_phone", { transport_type: "beacon" });
      }
    }, true);
  })();
</script>

<style is:global>
  /* Font self-hosted (OFL). Servono da /gentletest/fonts, niente round-trip a Google.
     Josefin Sans e un font variabile: lo stesso woff2 copre 400/600/700. */
  @font-face {
    font-family: "Josefin Sans";
    font-style: normal;
    font-weight: 400 700;
    font-display: swap;
    src: url("/gentletest/fonts/josefinsans-latin.woff2") format("woff2");
  }
  @font-face {
    font-family: "Libre Baskerville";
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url("/gentletest/fonts/librebaskerville-latin.woff2") format("woff2");
  }
  @font-face {
    font-family: "Libre Baskerville";
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url("/gentletest/fonts/librebaskerville-latin.woff2") format("woff2");
  }
  @font-face {
    font-family: "Libre Baskerville";
    font-style: italic;
    font-weight: 400;
    font-display: swap;
    src: url("/gentletest/fonts/librebaskerville-italic-latin.woff2") format("woff2");
  }
</style>

<style>
  .ccb {
    display: none;
    position: fixed;
    left: 16px;
    right: 16px;
    bottom: 16px;
    z-index: 60;
    max-width: 720px;
    margin: 0 auto;
    background: #2c1630;
    color: #fde6dc;
    border-radius: 14px;
    padding: 16px 18px;
    box-shadow: 0 12px 34px rgba(0, 0, 0, 0.35);
    align-items: center;
    gap: 14px;
    font-family: Georgia, serif;
  }
  .ccb--show { display: flex; }
  .ccb__txt { margin: 0; font-size: 0.92rem; line-height: 1.5; flex: 1; }
  .ccb__txt a { color: #fbd2bc; }
  .ccb__btns { display: flex; gap: 8px; flex: 0 0 auto; }
  .ccb__btn {
    font-family: "Josefin Sans", sans-serif; font-weight: 600; font-size: 0.9rem;
    border-radius: 999px; padding: 0.55rem 1.2rem; cursor: pointer; border: none;
  }
  .ccb__btn--ok { background: #fbd2bc; color: #3c1f40; }
  .ccb__btn--ghost { background: transparent; color: #fde6dc; border: 1px solid rgba(253, 230, 220, 0.5); }
  @media (max-width: 560px) {
    .ccb { flex-direction: column; align-items: stretch; }
    .ccb__btns { justify-content: flex-end; }
  }
</style>

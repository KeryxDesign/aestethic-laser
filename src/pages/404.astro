---
import Analytics from "../components/Analytics.astro";
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/png" href={`${base}/images/favicon.png`} />
    <title>Pagina non trovata | GentleTest</title>
    <link rel="preload" as="font" type="font/woff2" href={`${base}/fonts/josefinsans-latin.woff2`} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={`${base}/fonts/librebaskerville-latin.woff2`} crossorigin />
  </head>
  <body>
    <main class="nf">
      <div class="nf__box">
        <img src={`${base}/images/favicon.png`} alt="GentleTest" width="64" height="64" />
        <h1>Questa pagina non c'è.</h1>
        <p>Forse il link è vecchio o sbagliato. Torniamo sulla strada giusta.</p>
        <a class="nf__btn" href={base}>Vai al GentleTest</a>
      </div>
    </main>
    <style is:global>
      body { margin: 0; font-family: "Libre Baskerville", Georgia, serif; color: #3c1f40; background: linear-gradient(180deg, #fde6dc 0%, #fbd2bc 100%); }
      .nf { min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 2rem 1.4rem; }
      .nf__box { max-width: 480px; }
      .nf__box img { margin-bottom: 1rem; }
      .nf h1 { font-family: "Josefin Sans", sans-serif; font-weight: 700; font-size: clamp(1.6rem, 4vw, 2.2rem); margin: .4rem 0 .6rem; }
      .nf p { font-size: 1.05rem; margin: 0 0 1.6rem; }
      .nf__btn { display: inline-block; font-family: "Josefin Sans", sans-serif; font-weight: 700; text-decoration: none; background: #3c1f40; color: #fbf7f4; padding: .9rem 2.2rem; border-radius: 999px; box-shadow: 0 10px 26px rgba(60,31,64,.28); }
    </style>
    <Analytics />
  </body>
</html>

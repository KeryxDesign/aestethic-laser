---
import Analytics from "../components/Analytics.astro";
// Landing GentleTest — rebuild snello (~285 parole), copy MUSE + direzione DRD LORI
// Contrasto forte tra sezioni, enfasi DRD (bold/highlight/italic), piu' visual, no logo hero
const pageTitle = "GentleTest gratuito | Epilazione laser su misura a Palermo";
const pageDescription =
  "Hai già provato il laser e ti sei pentita? Prenota il GentleTest gratuito: troviamo il punto in cui senti il laser ma non fa male. Centro a Palermo.";
const canonical = "https://gentlebeam.it/gentletest";
const base = import.meta.env.BASE_URL; // "/gentletest/"
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={`${base}/images/marchio.png`} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://gentlebeam.it/gentletest/images/hero-persona.jpg" />
    <meta name="robots" content="index, follow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@400;500;600;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- 1 · HERO (plum scuro + foto = contrasto forte, niente logo) -->
    <header class="hero" id="prenota">
      <span
        class="hero__bg"
        aria-hidden="true"
        style={`background-image: linear-gradient(105deg, rgba(60,31,64,0.92) 0%, rgba(60,31,64,0.78) 48%, rgba(60,31,64,0.45) 100%), url(${base}/images/hero-persona.jpg)`}
      ></span>
      <div class="container hero__grid">
        <div class="hero__text">
          <h1>
            Se hai già provato il laser e ti sei pentita,
            <span class="hero__accent">forse non era colpa tua.</span>
          </h1>
          <p class="hero__sub">
            Soldi buttati, una macchia, i peli tornati. Non sei stata tu a
            sbagliare: nessuno aveva mai tarato il laser sulla <em>tua</em> pelle.
          </p>
          <ul class="hero__chips">
            <li>Gratuito</li>
            <li>Senza impegno</li>
            <li>Ti chiamiamo noi</li>
          </ul>
        </div>
        <div class="hero__formwrap">
          <form class="form" action={`${base}/lead.php`} method="POST">
            <p class="form__title">Prenota il tuo GentleTest gratuito</p>
            <p class="form__sub">Lascia i dati: ti chiamiamo noi per fissare l'orario.</p>
            <div class="form__row">
              <label for="nome">Nome</label>
              <input type="text" id="nome" name="nome" autocomplete="given-name" required />
            </div>
            <div class="form__row">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" autocomplete="email" required />
            </div>
            <div class="form__row">
              <label for="telefono">Telefono</label>
              <input type="tel" id="telefono" name="telefono" autocomplete="tel" required />
            </div>
            <div class="form__row">
              <label for="zona">Zona che ti interessa</label>
              <input type="text" id="zona" name="zona" placeholder="es. gambe, ascelle, inguine..." />
            </div>
            <input type="text" name="website" tabindex="-1" autocomplete="off" class="hp" aria-hidden="true" />
            <p class="form__privacy">
              I tuoi dati servono a ricontattarti per il GentleTest gratuito. Li
              trattiamo secondo l'<a href={`${base}/privacy`}>Informativa sulla
              privacy</a>.
            </p>
            <label class="form__check">
              <input type="checkbox" name="marketing" value="si" />
              <span>Acconsento a ricevere via email novità e offerte di GentleBeam
              (facoltativo, disiscrivibile quando vuoi).</span>
            </label>
            <button class="btn btn--block" type="submit">Prenota il mio GentleTest</button>
            <p class="form__foot">Gratuito, senza impegno. Dopo decidi tu.</p>
          </form>
        </div>
      </div>
    </header>

    <main>
      <!-- TESTIMONIANZE (recensioni Facebook reali) — subito sotto l'hero -->
      <section class="sec sec--plum">
        <div class="container">
          <div class="narrow narrow--head">
            <p class="kicker kicker--light">Cosa dicono le clienti</p>
            <h2>Le recensioni di chi è già venuta.</h2>
          </div>
          <div class="reviews">
            <article class="review">
              <p class="review__stars" aria-label="5 stelle su 5">★★★★★</p>
              <p class="review__text">&ldquo;Laser eccellente e super professionale.&rdquo;</p>
              <p class="review__who"><strong>Monica A.</strong><span>Consiglia su Facebook</span></p>
            </article>
            <article class="review">
              <p class="review__stars" aria-label="5 stelle su 5">★★★★★</p>
              <p class="review__text">&ldquo;Davvero un'ottima esperienza. Ho visto risultati già dalla prima seduta.&rdquo;</p>
              <p class="review__who"><strong>Alisea S.</strong><span>Consiglia su Facebook</span></p>
            </article>
            <article class="review">
              <p class="review__stars" aria-label="5 stelle su 5">★★★★★</p>
              <p class="review__text">&ldquo;Davvero ottimo! Soddisfatta già dalla prima seduta.&rdquo;</p>
              <p class="review__who"><strong>Rossana C.</strong><span>Consiglia su Facebook</span></p>
            </article>
            <article class="review">
              <p class="review__stars" aria-label="5 stelle su 5">★★★★★</p>
              <p class="review__text">&ldquo;Risultati già dalla prima seduta. Risultati bellissimi, esperienza di lusso.&rdquo;</p>
              <p class="review__who"><strong>Chiara P.</strong><span>Consiglia su Facebook</span></p>
            </article>
          </div>
          <p class="reviews__src">Recensioni reali dalla pagina Facebook di Gentle Beam.</p>
        </div>
      </section>

      <!-- 2 · MECCANISMO (cream + infografica soglia) -->
      <section class="sec sec--cream">
        <div class="container split">
          <div class="split__text">
            <p class="kicker">Il metodo</p>
            <p class="lead"><strong>Partiamo piano e saliamo poco alla volta.</strong></p>
            <p>
              Ci fermiamo nel punto in cui <em>senti il laser ma non fa male</em>:
              la tua <em>soglia di comfort</em>. È anche la potenza che elimina
              davvero il follicolo.
            </p>
            <p>
              Partire piano, e non dalla potenza massima, è il modo di trattare la
              pelle senza forzarla.
            </p>
            <p class="micro">Comfort ed efficacia sono lo stesso punto.</p>
          </div>
          <div class="scale panel" aria-hidden="true">
            <div class="scale__track">
              <span class="scale__fill"></span>
              <span class="scale__marker">
                <span class="bfly"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 6c-1.1-2-3.4-3.1-5.6-2.7C4.3 3.7 2.8 5.4 2.7 7.5c-.1 2.2 1.5 3.8 3.6 4.5-1.5.8-2.4 2.2-2.2 3.8.2 1.6 1.6 2.7 3.2 2.6 1.9-.1 3.4-1.6 4.7-3.5 1.3 1.9 2.8 3.4 4.7 3.5 1.6.1 3-1 3.2-2.6.2-1.6-.7-3-2.2-3.8 2.1-.7 3.7-2.3 3.6-4.5-.1-2.1-1.6-3.8-3.7-4.2C15.4 2.9 13.1 4 12 6z"/></svg></span>
                <span class="scale__mlabel">la tua soglia</span>
              </span>
            </div>
            <div class="scale__ends">
              <span>potenza bassa<br /><small>non senti nulla</small></span>
              <span class="r">potenza fissa<br /><small>uguale per tutte</small></span>
            </div>
          </div>
        </div>
      </section>

      <!-- 3 · PERCHE ALTROVE STORTO (peach + confronto A/B) -->
      <section class="sec sec--peach">
        <div class="container">
          <div class="head">
            <p class="kicker">La differenza</p>
            <p class="lead">
              <strong>Molti centri partono dalla potenza fissa della macchina,
              uguale per tutte.</strong> Cinque clienti l'ora, fretta, e la pelle
              che paga il conto.
            </p>
          </div>
          <div class="diff-photo">
            <img
              src={`${base}/images/gambe-lisce.jpg`}
              alt="Pelle liscia, trattata con cura"
              width="760"
              height="475"
            />
          </div>
          <div class="ab">
            <div class="ab__card ab__card--bad">
              <span class="ab__label">&#10007; Altri centri</span>
              <span class="ab__ico">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
              </span>
              <p>Potenza fissa · 5 clienti l'ora · di corsa</p>
            </div>
            <div class="ab__vs">vs</div>
            <div class="ab__card ab__card--good">
              <span class="ab__label">&#10003; Il nostro metodo</span>
              <span class="ab__ico">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="3.4"/><path d="M12 1.5v3M12 19.5v3M1.5 12h3M19.5 12h3"/></svg>
              </span>
              <p>Misurato su <em>di te</em> · col tempo che serve</p>
            </div>
          </div>
        </div>
      </section>

      <!-- 4 · CABINA (plum + icona grande) -->
      <section class="sec sec--plum sec--center">
        <div class="container narrow">
          <div class="glass">
            <span class="bigico">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="11" height="18" rx="1"/><path d="M16 3l3 1.5V21l-3-1"/><circle cx="12.5" cy="12" r="0.9" fill="currentColor"/><path d="M2 12h2.5M19.5 8.5l1.7-1.2M19.5 15.5l1.7 1.2"/></svg>
            </span>
            <p class="lead">
              <strong>La cabina è a norma: se si apre la porta, il laser si ferma
              da solo.</strong>
            </p>
            <p class="cabina__who">
              E a seguirti è un'estetista qualificata, con formazione certificata
              sull'uso del laser.
            </p>
          </div>
        </div>
      </section>

      <!-- 5 · ONESTA (cream + calendario) -->
      <section class="sec sec--cream">
        <div class="container split split--rev">
          <div class="split__text">
            <p class="kicker">Onestà</p>
            <p class="lead">
              <strong>L'epilazione laser è permanente, non "definitiva per
              sempre".</strong>
            </p>
            <p>
              Col tempo servono dei richiami, poche sedute per mantenere il
              risultato. Preferiamo dirtelo prima, così sai cosa aspettarti.
            </p>
          </div>
          <div class="split__media">
            <img
              src={`${base}/images/dettaglio-pelle.jpg`}
              alt="Pelle sana e luminosa"
              width="520"
              height="340"
            />
          </div>
        </div>
      </section>

      <!-- 6 · OFFERTA (peach + foto) -->
      <section class="sec sec--peach">
        <div class="container split">
          <div class="split__media">
            <img
              src={`${base}/images/serena.jpg`}
              alt="Donna serena dopo il trattamento"
              width="520"
              height="340"
            />
          </div>
          <div class="split__text">
            <p class="kicker">Il GentleTest</p>
            <p class="lead">
              <strong>Il GentleTest è gratuito: proviamo insieme e troviamo la tua
              soglia.</strong>
            </p>
            <p>
              Zona per zona, trovi la tua soglia. Esci sapendo esattamente cosa
              sente la tua pelle, senza aver comprato nulla.
            </p>
          </div>
        </div>
        {/* [DA CONFERMARE] foto reale della professionista da Greg per il "chi siamo" */}
      </section>


      <!-- 7a · PROVE REALI (chat + video vocali) -->
      <section class="sec sec--plum">
        <div class="container">
          <div class="narrow narrow--head">
            <p class="kicker kicker--light">Conversazioni vere</p>
            <h2>Le clienti, con parole loro.</h2>
          </div>
          <figure class="chatproof">
            <img
              src={`${base}/images/chat-luana.jpg`}
              alt="Conversazione reale con una cliente"
              width="1263"
              height="615"
              loading="lazy"
            />
            <figcaption>Una conversazione vera con una cliente. I contatti a lato sono oscurati per privacy.</figcaption>
          </figure>
          <div class="vmsgs">
            <p class="vmsgs__title">Messaggi vocali e scambi reali sui risultati</p>
            <div class="vmsgs__grid">
              <video class="vmsg" controls preload="none" playsinline poster={`${base}/videos/poster-1.jpg`} src={`${base}/videos/testimonianza-vocale-1.mp4`}></video>
              <video class="vmsg" controls preload="none" playsinline poster={`${base}/videos/poster-2.jpg`} src={`${base}/videos/testimonianza-vocale-2.mp4`}></video>
              <video class="vmsg" controls preload="none" playsinline poster={`${base}/videos/poster-3.jpg`} src={`${base}/videos/testimonianza-vocale-3.mp4`}></video>
            </div>
          </div>
        </div>
      </section>

      <!-- 7b · CTA FINALE (form ripetuto) -->
      <section class="sec sec--cta" id="prenota2">
        <div class="container">
          <div class="narrow narrow--head">
            <p class="kicker">Prenota ora</p>
            <h2>Provalo gratis: ti chiamiamo noi.</h2>
          </div>
          <div class="ctaform">
            <form class="form" action={`${base}/lead.php`} method="POST">
              <p class="form__title">Prenota il tuo GentleTest gratuito</p>
              <p class="form__sub">Lascia i dati: ti chiamiamo noi per fissare l'orario.</p>
              <div class="form__row">
                <label for="nome2">Nome</label>
                <input type="text" id="nome2" name="nome" autocomplete="given-name" required />
              </div>
              <div class="form__row">
                <label for="email2">Email</label>
                <input type="email" id="email2" name="email" autocomplete="email" required />
              </div>
              <div class="form__row">
                <label for="telefono2">Telefono</label>
                <input type="tel" id="telefono2" name="telefono" autocomplete="tel" required />
              </div>
              <div class="form__row">
                <label for="zona2">Zona che ti interessa</label>
                <input type="text" id="zona2" name="zona" placeholder="es. gambe, ascelle, inguine..." />
              </div>
              <input type="text" name="website" tabindex="-1" autocomplete="off" class="hp" aria-hidden="true" />
              <p class="form__privacy">
                I tuoi dati servono a ricontattarti per il GentleTest gratuito. Li
                trattiamo secondo l'<a href={`${base}/privacy`}>Informativa sulla
                privacy</a>.
              </p>
              <label class="form__check">
                <input type="checkbox" name="marketing" value="si" />
                <span>Acconsento a ricevere via email novità e offerte di GentleBeam
                (facoltativo, disiscrivibile quando vuoi).</span>
              </label>
              <button class="btn btn--block" type="submit">Prenota il mio GentleTest</button>
              <p class="form__foot">Gratuito, senza impegno. Dopo decidi tu.</p>
            </form>
          </div>
        </div>
      </section>

      <!-- 8 · DOVE SIAMO (mappa + orari + contatti) -->
      <section class="sec sec--cream">
        <div class="container">
          <div class="narrow narrow--head">
            <p class="kicker">Dove siamo</p>
            <h2>Vieni a trovarci, a Palermo.</h2>
          </div>
          <div class="locate">
            <div class="locate__map">
              <iframe
                title="Mappa centro GentleTest"
                src="https://www.google.com/maps?q=Via+Giuseppe+Sciuti+109,+90144+Palermo&output=embed"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
            </div>
            <div class="locate__info">
              <p><span class="locate__lbl">Indirizzo</span><br />Via Giuseppe Sciuti 109, 90144 Palermo (PA)</p>
              <p><span class="locate__lbl">Orari</span><br />Lun&ndash;Ven: 09:00&ndash;13:00 e 15:00&ndash;19:00</p>
              <p>
                <span class="locate__lbl">Contatti</span><br />
                Tel: <a href="tel:+393923038077">+39 392 303 8077</a><br />
                WhatsApp: <a href="https://wa.me/393923038077?text=Ciao%20Gregorio%2C%20vorrei%20informazioni%20sul%20GentleTest" target="_blank" rel="noopener">scrivici su WhatsApp</a><br />
                Email: <a href="mailto:info@gentlebeam.it">info@gentlebeam.it</a>
              </p>
              <a class="btn" href="#prenota2">Prenota il tuo GentleTest</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container narrow">
        <p class="footer__d">
          I risultati possono variare da persona a persona. Trattamento di natura
          estetica, non sostituisce un consulto medico.
        </p>
        <p class="footer__legal">
          Pillitteri Gregorio — Via Giuseppe Sciuti 109, 90144 Palermo (PA) —
          P.IVA 06562460821 — REA PA-457433 — PEC pillitterigregorio@pec.it
        </p>
        <p class="footer__c">
          info@gentlebeam.it · <a href="tel:+393923038077">+39 392 303 8077</a> ·
          <a href="https://www.facebook.com/profile.php?id=100089144112601" target="_blank" rel="noopener">Facebook</a> ·
          <a href={`${base}/privacy`}>Privacy Policy</a>
        </p>
      </div>
    </footer>

    <a
      class="wa-float"
      href="https://wa.me/393923038077?text=Ciao%20Gregorio%2C%20vorrei%20informazioni%20sul%20GentleTest"
      target="_blank"
      rel="noopener"
      aria-label="Scrivici su WhatsApp"
    >
      <svg viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 3C9.4 3 4 8.4 4 15c0 2.1.6 4.1 1.6 5.9L4 29l8.3-1.6c1.7.9 3.6 1.4 5.7 1.4 6.6 0 12-5.4 12-12S22.6 3 16 3zm0 21.8c-1.8 0-3.5-.5-5-1.4l-.4-.2-4.9 1 1-4.8-.3-.4c-1-1.6-1.5-3.4-1.5-5.3C4.4 9.6 9.6 4.4 16 4.4S27.6 9.6 27.6 16 22.4 24.8 16 24.8zm6.5-7.9c-.4-.2-2.1-1-2.4-1.1-.3-.1-.6-.2-.8.2-.2.4-.9 1.1-1.1 1.3-.2.2-.4.2-.8.1-.4-.2-1.5-.6-2.9-1.8-1.1-1-1.8-2.2-2-2.6-.2-.4 0-.6.2-.8.2-.2.4-.4.5-.6.2-.2.2-.4.4-.6.1-.2.1-.5 0-.7-.1-.2-.8-2-1.1-2.7-.3-.7-.6-.6-.8-.6h-.7c-.2 0-.6.1-.9.5-.3.4-1.2 1.2-1.2 2.9 0 1.7 1.2 3.3 1.4 3.6.2.2 2.4 3.7 5.8 5.1.8.3 1.4.5 1.9.7.8.3 1.5.2 2.1.1.6-.1 2.1-.9 2.4-1.7.3-.8.3-1.5.2-1.7-.1-.2-.3-.2-.7-.4z"/></svg>
    </a>

    <Analytics />

    <style is:global>
      :root {
        --peach-light: #fde6dc;
        --peach: #fbd2bc;
        --plum: #3c1f40;
        --plum-2: #2c1630;
        --plum-soft: #5a3460;
        --cream: #fbf7f4;
        --paper: #fff;
        --line: #ecdfd8;
        --max: 1080px;
        --narrow: 680px;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: "Libre Baskerville", Georgia, serif;
        font-size: 1.125rem;
        line-height: 1.7;
        color: var(--plum);
        background: var(--cream);
      }
      h1, h2 { font-family: "Josefin Sans", sans-serif; font-weight: 600; line-height: 1.16; margin: 0 0 1rem; }
      .sec h2 { font-size: clamp(1.5rem, 3vw, 1.9rem); }
      p { margin: 0 0 1rem; }
      em { font-style: italic; }
      strong { font-weight: 700; }
      .container { width: 100%; max-width: var(--max); margin: 0 auto; padding: 0 1.4rem; }
      .narrow { max-width: var(--narrow); margin: 0 auto; }
      .micro { font-size: 0.98rem; color: var(--plum-soft); }
      /* titoli di sezione (fanno da h2) */
      .lead { font-family: "Josefin Sans", sans-serif; font-weight: 600; font-size: clamp(1.5rem, 3vw, 1.9rem); line-height: 1.25; }
      .lead strong { font-weight: 700; }

      .kicker {
        font-family: "Josefin Sans", sans-serif; font-weight: 700; font-size: 0.98rem;
        text-transform: uppercase; letter-spacing: 0.16em; margin: 0 0 0.7rem;
      }

      /* highlight DRD */
      .hl {
        display: inline-block;
        background: var(--peach);
        color: var(--plum);
        font-weight: 700;
        padding: 0.25em 0.55em;
        border-radius: 6px;
        line-height: 1.5;
      }
      .hl--center { display: block; text-align: center; margin-top: 1.4rem; }

      /* SECTIONS — contrasto netto */
      .sec { padding: 4.5rem 0; }
      .sec--cream { background: var(--cream); }
      .sec--peach { background: var(--peach-light); }
      .sec--plum { background: var(--plum); color: var(--peach-light); }
      .sec--plum .kicker { color: var(--peach); }
      .sec--plum .hl { background: var(--peach); color: var(--plum); }
      .sec--center { text-align: center; }
      .cabina__who { font-size: 1rem; opacity: .88; margin: .8rem 0 0; }
      .head { max-width: var(--narrow); margin: 0 auto 2rem; text-align: center; }

      /* BUTTON */
      .btn {
        display: inline-block; font-family: "Josefin Sans", sans-serif; font-weight: 700;
        font-size: 1.08rem; letter-spacing: 0.03em; text-decoration: none; cursor: pointer;
        padding: 1rem 2.4rem; border: none; border-radius: 999px;
        background: var(--plum); color: var(--cream);
        box-shadow: 0 10px 26px rgba(60,31,64,0.32); transition: transform .15s, box-shadow .15s;
      }
      .btn:hover { transform: translateY(-2px); box-shadow: 0 14px 34px rgba(60,31,64,0.42); }
      /* hero scuro: bottone bianco = massimo contrasto */
      .btn--block { width: 100%; margin-top: .5rem; }

      /* HERO form-first */
      .hero { position: relative; background: var(--plum); color: var(--peach-light); padding: 3.4rem 0; overflow: hidden; }
      .hero__bg { position: absolute; inset: 0; background-size: cover; background-position: center 25%; z-index: 0; }
      .hero__grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 2.6rem; align-items: center; }
      .hero h1 { font-size: clamp(1.9rem, 4.4vw, 2.8rem); color: #fff; }
      .hero__accent { display: block; font-family: "Libre Baskerville", serif; font-style: italic; font-weight: 700; color: var(--peach); margin-top: .3rem; }
      .hero__sub { font-size: 1.12rem; line-height: 1.5; max-width: 30rem; }
      .hero__chips { list-style: none; display: flex; flex-wrap: wrap; gap: .6rem; padding: 0; margin: 1.4rem 0 0; }
      .hero__chips li { font-family: "Josefin Sans", sans-serif; font-weight: 600; font-size: .85rem; color: var(--plum); background: var(--peach); padding: .35rem .8rem; border-radius: 999px; }
      .hero__chips li::before { content: "\2713\00a0"; }
      .hero__formwrap .form { margin: 0; }
      .form__title { font-family: "Josefin Sans", sans-serif; font-weight: 700; font-size: 1.3rem; color: var(--plum); margin: 0 0 .2rem; }
      .form__sub { font-size: .95rem; color: var(--plum-soft); margin: 0 0 1.2rem; }
      .form__foot { text-align: center; font-family: "Josefin Sans", sans-serif; font-size: .85rem; color: var(--plum-soft); margin: .9rem 0 0; }

      /* DOVE SIAMO */
      .locate { display: grid; grid-template-columns: 1.2fr .8fr; gap: 1.8rem; align-items: stretch; }
      .locate__map { border-radius: 18px; overflow: hidden; box-shadow: 0 12px 30px rgba(60,31,64,.12); min-height: 320px; }
      .locate__map iframe { width: 100%; height: 100%; min-height: 320px; border: 0; display: block; }
      .locate__info { display: flex; flex-direction: column; justify-content: center; }
      .locate__info p { font-size: 1.02rem; margin: 0 0 1.1rem; }
      .locate__info a { color: var(--plum); }
      .locate__lbl { font-family: "Josefin Sans", sans-serif; font-weight: 700; font-size: .78rem; text-transform: uppercase; letter-spacing: .12em; color: var(--plum-soft); }
      .locate__info .btn { align-self: flex-start; margin-top: .4rem; color: var(--cream); }

      /* CTA finale: form ripetuto */
      .sec--cta { background: var(--plum); color: var(--cream); }
      .sec--cta .kicker { color: var(--peach); }
      .sec--cta h2 { color: var(--cream); }
      .ctaform { max-width: 560px; margin: 1.6rem auto 0; }

      /* TESTIMONIANZE */
      .reviews { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 1.2rem; }
      .review { background: var(--paper); color: var(--plum); border-radius: 16px; padding: 1.4rem 1.5rem; box-shadow: 0 10px 26px rgba(0,0,0,.18); }
      .review__stars { margin: 0 0 .55rem; color: #e0a417; font-size: 1.02rem; letter-spacing: .12em; line-height: 1; }
      .vmsgs { margin-top: 2.2rem; }
      .vmsgs__title { text-align: center; font-family: "Josefin Sans", sans-serif; color: var(--peach); font-size: 1.02rem; margin: 0 0 1rem; }
      .vmsgs__grid { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; align-items: flex-start; }
      .vmsg { width: 100%; max-width: 340px; border-radius: 12px; background: #000; box-shadow: 0 10px 26px rgba(0,0,0,.28); }
      .review__text { font-family: "Libre Baskerville", serif; font-style: italic; font-size: 1.05rem; line-height: 1.5; margin: 0 0 1rem; }
      .review__who { font-family: "Josefin Sans", sans-serif; margin: 0; }
      .review__who strong { display: block; color: var(--plum); font-size: .98rem; }
      .review__who span { color: var(--plum-soft); font-size: .8rem; }
      .chatproof { margin: 1.8rem auto 0; max-width: 680px; text-align: center; }
      .chatproof img { width: 100%; height: auto; border-radius: 14px; box-shadow: 0 14px 34px rgba(0,0,0,.28); }
      .chatproof figcaption { font-family: "Josefin Sans", sans-serif; font-size: .82rem; color: var(--peach); margin-top: .7rem; opacity: .9; }
      .reviews__src { text-align: center; font-size: .85rem; margin-top: 1.4rem; opacity: .8; }

      /* WHATSAPP floating */
      .wa-float { position: fixed; right: 18px; bottom: 18px; z-index: 50; width: 58px; height: 58px; border-radius: 50%; background: #25d366; color: #fff; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 22px rgba(0,0,0,.28); transition: transform .15s ease; }
      .wa-float:hover { transform: scale(1.07); }
      .wa-float svg { width: 32px; height: 32px; }

      /* BANDA texture full-width */
      .band { height: 240px; background-size: cover; background-position: center 42%; }

      /* foto sezione differenza */
      .diff-photo { max-width: 760px; margin: 0 auto 1.8rem; }
      .diff-photo img { width: 100%; height: auto; aspect-ratio: 16/10; object-fit: cover; border-radius: 18px; box-shadow: 0 12px 30px rgba(60,31,64,.14); }

      /* SPLIT (testo + visual) */
      .split { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 2.6rem; align-items: center; }
      .split--rev .split__text { order: 2; }
      .split__media img { width: 100%; height: auto; aspect-ratio: 3/2; object-fit: cover; border-radius: 18px; box-shadow: 0 14px 34px rgba(60,31,64,.16); }

      /* SCALE infografica */
      .scale__track {
        position: relative; height: 16px; border-radius: 999px;
        background: linear-gradient(90deg, var(--line), var(--peach) 65%, var(--plum-soft));
        margin: 2.4rem 0 .6rem;
      }
      .scale__fill { position: absolute; inset: 0; border-radius: 999px; }
      .scale__marker { position: absolute; left: 65%; top: 50%; transform: translate(-50%,-50%); text-align: center; }
      .scale__marker .bfly { display: block; color: var(--plum); }
      .scale__marker .bfly svg { width: 30px; height: 30px; }
      .scale__mlabel {
        position: absolute; left: 50%; transform: translateX(-50%); top: 30px; white-space: nowrap;
        font-family: "Josefin Sans", sans-serif; font-weight: 600; font-size: .8rem; color: var(--plum);
        background: var(--paper); border: 1px solid var(--line); padding: .15rem .5rem; border-radius: 999px;
      }
      .scale__ends { display: flex; justify-content: space-between; font-family: "Josefin Sans", sans-serif; font-size: .82rem; color: var(--plum-soft); margin-top: 1.6rem; }
      .scale__ends .r { text-align: right; }
      .scale__ends small { opacity: .7; }

      /* AB confronto */
      .ab { display: grid; grid-template-columns: 1fr auto 1fr; gap: 1.2rem; align-items: stretch; max-width: 760px; margin: 0 auto; }
      .ab__card { background: var(--paper); border-radius: 16px; padding: 1.6rem; text-align: center; }
      .ab__card--bad { border: 2px solid #e3b3ad; color: var(--plum); }
      .ab__card--good { border: 2px solid #aed4b9; color: var(--plum); box-shadow: 0 8px 22px rgba(47,143,87,.14); }
      .ab__card p { margin: 0; font-size: 1.02rem; }
      .ab__label { display: block; font-family: "Josefin Sans", sans-serif; font-weight: 700; font-size: .82rem; letter-spacing: .04em; margin-bottom: .7rem; }
      .ab__card--bad .ab__label { color: #c0392b; }
      .ab__card--good .ab__label { color: #2f8f57; }
      .ab__ico { display: inline-flex; width: 52px; height: 52px; align-items: center; justify-content: center; border-radius: 50%; margin-bottom: .8rem; }
      .ab__card--bad .ab__ico { background: #f7e3e0; color: #c0392b; }
      .ab__card--good .ab__ico { background: #e4f2e8; color: #2f8f57; }
      .ab__ico svg { width: 28px; height: 28px; }
      .ab__vs { align-self: center; font-family: "Josefin Sans", sans-serif; font-weight: 700; color: var(--plum-soft); }

      /* big icon / icon wrap */
      .bigico { display: inline-flex; width: 76px; height: 76px; align-items: center; justify-content: center; border-radius: 50%; background: rgba(251,210,188,.18); color: var(--peach); margin-bottom: 1.2rem; }
      .bigico svg { width: 42px; height: 42px; }
      .iconwrap { display: flex; justify-content: center; }
      .iconwrap__ico { display: inline-flex; width: 120px; height: 120px; align-items: center; justify-content: center; border-radius: 28px; background: var(--peach-light); color: var(--plum); }
      .iconwrap__ico svg { width: 60px; height: 60px; }

      /* FORM */
      .form { background: var(--paper); color: var(--plum); padding: 1.8rem; border-radius: 18px; box-shadow: 0 12px 32px rgba(60,31,64,.1); border: 1px solid var(--line); margin-top: 1rem; }
      .form__row { margin-bottom: 1rem; display: flex; flex-direction: column; }
      .form__row label { font-family: "Josefin Sans", sans-serif; font-weight: 600; margin-bottom: .35rem; color: var(--plum); }
      .form__row input { font-family: "Libre Baskerville", serif; font-size: 1rem; padding: .8rem .9rem; border: 1.5px solid var(--line); border-radius: 10px; background: #fff; color: var(--plum); }
      .form__row input:focus { outline: none; border-color: var(--plum); box-shadow: 0 0 0 3px rgba(60,31,64,.12); }
      .hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
      .form__privacy { font-size: .9rem; color: var(--plum-soft); margin: .2rem 0 1rem; }
      .form__privacy a { color: var(--plum); }
      .form__check { display: flex; gap: .6rem; align-items: flex-start; font-size: .92rem; color: var(--plum-soft); margin: 0 0 1.2rem; cursor: pointer; line-height: 1.4; }
      .form__check input { margin-top: .25rem; width: 18px; height: 18px; flex: 0 0 auto; accent-color: var(--plum); }
      .trust { list-style: none; display: flex; flex-wrap: wrap; justify-content: center; gap: 1.4rem; padding: 0; margin: 1.4rem 0 0; font-family: "Josefin Sans", sans-serif; font-size: .85rem; color: var(--plum-soft); }
      .trust li { display: inline-flex; align-items: center; gap: .4rem; }
      .trust svg { width: 18px; height: 18px; }

      /* FOOTER */
      .footer { background: var(--plum-2); color: var(--peach-light); padding: 2.2rem 0; font-size: .82rem; line-height: 1.6; }
      .footer__d { opacity: .78; }
      .footer__legal { opacity: .62; font-size: .76rem; margin: .6rem 0; }
      .footer__c { font-family: "Josefin Sans", sans-serif; margin: 0; }
      .footer a { color: var(--peach); }

      /* ===== LIVELLO IN PIU': riquadri, profondita', movimento ===== */
      /* riquadro generico (es. infografica soglia) */
      .panel {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 1.8rem 1.6rem;
        box-shadow: 0 14px 36px rgba(60, 31, 64, 0.08);
      }
      /* riquadro "vetro" su fondo plum */
      .glass {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(251, 210, 188, 0.35);
        border-radius: 20px;
        padding: 2.4rem 2rem;
        backdrop-filter: blur(2px);
      }
      /* profondita': blob sfocati morbidi dietro alle sezioni chiare */
      .sec--cream, .sec--peach { position: relative; overflow: hidden; }
      .sec--cream::before, .sec--peach::before {
        content: ""; position: absolute; width: 380px; height: 380px; border-radius: 50%;
        background: radial-gradient(circle, rgba(251,210,188,0.5), rgba(251,210,188,0));
        top: -140px; right: -120px; pointer-events: none; z-index: 0;
      }
      .sec--peach::before { background: radial-gradient(circle, rgba(255,255,255,0.55), rgba(255,255,255,0)); }
      .sec > .container { position: relative; z-index: 1; }

      /* micro-interazioni hover */
      .myth-card, .featcard, .ab__card, .step, .panel, .split__media img, .compare__card {
        transition: transform .22s ease, box-shadow .22s ease;
      }
      .myth-card:hover, .featcard:hover, .ab__card:hover, .panel:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 44px rgba(60, 31, 64, 0.14);
      }
      .split__media img:hover { transform: scale(1.015); }
      .step:hover .step__num { transform: scale(1.08); }
      .step__num { transition: transform .22s ease; display: inline-block; }
      .btn { will-change: transform; }

      /* reveal allo scroll (attivo solo con JS = classe .anim su <html>) */
      .anim .reveal { opacity: 0; transform: translateY(26px); transition: opacity .7s cubic-bezier(.2,.7,.2,1), transform .7s cubic-bezier(.2,.7,.2,1); }
      .anim .reveal.in { opacity: 1; transform: none; }

      /* infografica soglia: il marker scorre fino alla soglia quando entra in vista */
      .anim .scale .scale__marker { left: 6%; opacity: 0; transition: left 1.1s cubic-bezier(.2,.7,.2,1) .25s, opacity .5s ease .25s; }
      .anim .scale.in .scale__marker { left: 65%; opacity: 1; }

      @media (prefers-reduced-motion: reduce) {
        .anim .reveal, .anim .reveal.in { opacity: 1 !important; transform: none !important; transition: none !important; }
        .anim .scale .scale__marker { left: 65%; opacity: 1; transition: none; }
        .myth-card, .featcard, .ab__card, .panel, .split__media img, .step__num { transition: none; }
      }

      @media (max-width: 860px) {
        .hero__grid, .split, .locate { grid-template-columns: 1fr; gap: 1.8rem; }
        .split--rev .split__text { order: 0; }
        .iconwrap { order: -1; }
        .ab { grid-template-columns: 1fr; }
        .ab__vs { padding: .2rem 0; }
        .hero__bg { background-position: center 18%; }
      }
      @media (max-width: 600px) {
        body { font-size: 1rem; }
        .sec { padding: 3rem 0; }
        .hero { padding: 2.4rem 0; }
      }
    </style>

    <script is:inline>
      (() => {
        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        document.documentElement.classList.add('anim');
        const sel = '.kicker, .lead, h1, .hero__sub, .myth-card, .featcard, .ab__card, .step, .scale, .split__media, .pullquote, .closing__title, .form, .bigico, .cabina__who, .trust';
        const els = Array.from(document.querySelectorAll(sel));
        els.forEach((el) => {
          el.classList.add('reveal');
          // piccolo stagger fra fratelli nelle griglie
          const sibs = el.parentElement ? Array.from(el.parentElement.children).filter(c => c.classList.contains('reveal')) : [];
          const i = sibs.indexOf(el);
          if (i > 0) el.style.transitionDelay = Math.min(i, 4) * 0.09 + 's';
        });
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>

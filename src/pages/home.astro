---
import Analytics from "../components/Analytics.astro";
// HOME gentlebeam.it — copy MUSE verbatim + direttive LORI (ritmo fondi, CTA discipline)
// Buildata in dist/home/index.html; il deploy la copia alla ROOT del dominio.
// Gli asset restano sotto /gentletest/: percorsi sempre assoluti con ${base}.
const pageTitle = "Gentle Beam · Epilazione laser e centro estetico a Palermo";
const pageDescription =
  "Epilazione laser donna e uomo, cera, manicure, massaggi e trattamenti viso a Palermo, in via Sciuti 109. Prenota online o prova il GentleTest gratuito.";
const canonical = "https://gentlebeam.it/";
const base = import.meta.env.BASE_URL; // "/gentletest/"
const BOOKING = "https://www.sumupbookings.com/gentlebeam";
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={`${base}/images/favicon.png`} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://gentlebeam.it/gentletest/images/hero-persona.jpg" />
    <meta name="robots" content="index, follow" />
    <!-- Preload immagine LCP dell'hero -->
    <link rel="preload" as="image" href={`${base}/images/hero-persona.webp`} fetchpriority="high" />
    <!-- Preload font critici above-the-fold -->
    <link rel="preload" as="font" type="font/woff2" href={`${base}/fonts/josefinsans-latin.woff2`} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={`${base}/fonts/librebaskerville-latin.woff2`} crossorigin />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BeautySalon",
      "name": "Gentle Beam",
      "image": "https://gentlebeam.it/gentletest/images/hero-persona.jpg",
      "url": "https://gentlebeam.it/",
      "telephone": "+393923038077",
      "email": "info@gentlebeam.it",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Via Giuseppe Sciuti 109",
        "postalCode": "90144",
        "addressLocality": "Palermo",
        "addressRegion": "PA",
        "addressCountry": "IT"
      },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "08:00", "closes": "13:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "14:00", "closes": "18:00" }
      ],
      "sameAs": [
        "https://www.facebook.com/profile.php?id=100089144112601",
        "https://www.instagram.com/gentlebeamitalia"
      ]
    })} />
  </head>

  <body>
    <!-- SITE HEADER (compresso: 64px, logo 52px) -->
    <nav class="site-header" aria-label="Navigazione principale">
      <div class="site-header__inner">
        <a href="/" class="site-header__logo" aria-label="Gentle Beam — home">
          <img src={`${base}/images/logo-color.webp`} alt="Gentle Beam" width="140" height="100" />
        </a>
        <ul class="site-header__nav" role="list">
          <li><a href="#servizi">Servizi</a></li>
          <li class="nav-keep"><a href="/gentletest/">GentleTest</a></li>
          <li><a href="#contatti">Contatti</a></li>
        </ul>
        <a href={BOOKING} target="_blank" rel="noopener" class="site-header__cta">Prenota</a>
      </div>
    </nav>

    <!-- 1 · HERO (plum + foto, una sola CTA) -->
    <header class="hero">
      <span
        class="hero__bg"
        aria-hidden="true"
        style={`background-image: linear-gradient(105deg, rgba(60,31,64,0.92) 0%, rgba(60,31,64,0.78) 48%, rgba(60,31,64,0.45) 100%), url(${base}/images/hero-persona.webp)`}
      ></span>
      <div class="container hero__wrap">
        <div class="hero__text">
          <h1>
            Epilazione laser e trattamenti estetici
            <span class="hero__accent">a Palermo</span>
          </h1>
          <p class="hero__sub">
            Siamo Gentle Beam, in via Sciuti 109: epilazione laser su misura,
            estetica e cura della pelle.
          </p>
          <a class="btn btn--peach" href={BOOKING} target="_blank" rel="noopener">Prenota un appuntamento</a>
          <p class="cta-note cta-note--dark">Si apre il calendario online del centro: scegli servizio, giorno e ora.</p>
        </div>
      </div>
    </header>

    <main>
      <!-- 2 · SERVIZI (peach-light, 6 card cliccabili) -->
      <section class="sec sec--peach" id="servizi">
        <div class="container">
          <div class="narrow narrow--head">
            <h2>Laser, cera, mani, massaggi: prenoti tutto online.</h2>
            <p class="sechead__sub">Ogni servizio ha il prezzo indicato e si prenota dal calendario del centro.</p>
          </div>
          <div class="svcs">
            <a class="svc" href={BOOKING} target="_blank" rel="noopener" aria-label="Epilazione laser donna — apri il calendario e prenota">
              <span class="svc__ico" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v4.2M7.2 4.3l2 3.5M16.8 4.3l-2 3.5"/><path d="M4 17c2.6-2.2 5.2-3.3 8-3.3s5.4 1.1 8 3.3"/><path d="M18.6 8.6l.4 1.1 1.1.4-1.1.4-.4 1.1-.4-1.1-1.1-.4 1.1-.4z"/></svg>
              </span>
              <span class="svc__name">Epilazione laser donna</span>
              <span class="svc__desc">zona per zona o percorsi completi</span>
            </a>
            <a class="svc" href={BOOKING} target="_blank" rel="noopener" aria-label="Epilazione laser uomo — apri il calendario e prenota">
              <span class="svc__ico" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="8.5" y="3" width="7" height="5" rx="1"/><path d="M10.4 10.5v2.6M12 10.5v3.6M13.6 10.5v2.6"/><path d="M12 8v2.5"/><path d="M5 19.5h14"/></svg>
              </span>
              <span class="svc__name">Epilazione laser uomo</span>
              <span class="svc__desc">tutte le zone, barba compresa</span>
            </a>
            <a class="svc" href={BOOKING} target="_blank" rel="noopener" aria-label="Epilazione con cera — apri il calendario e prenota">
              <span class="svc__ico" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.5c3.2 4 5.3 6.6 5.3 9.3a5.3 5.3 0 1 1-10.6 0C6.7 10.1 8.8 7.5 12 3.5z"/></svg>
              </span>
              <span class="svc__name">Epilazione con cera</span>
              <span class="svc__desc">per chi preferisce il metodo classico</span>
            </a>
            <a class="svc" href={BOOKING} target="_blank" rel="noopener" aria-label="Manicure e pedicure — apri il calendario e prenota">
              <span class="svc__ico" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9.5" y="2.5" width="5" height="4.2" rx="0.8"/><path d="M12 6.7v2.3"/><rect x="8" y="9" width="8" height="12" rx="2.2"/></svg>
              </span>
              <span class="svc__name">Manicure e pedicure</span>
              <span class="svc__desc">cura di mani e piedi</span>
            </a>
            <a class="svc" href={BOOKING} target="_blank" rel="noopener" aria-label="Massaggi — apri il calendario e prenota">
              <span class="svc__ico" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.5c1.8 2 2.7 3.9 2.7 5.7S13.5 12.6 12 12.6s-2.7-1.6-2.7-3.4S10.2 5.5 12 3.5z"/><path d="M4.5 9.5c2.6.3 4.6 1.3 6 3 .9 1.1 1.4 2.5 1.5 4.1-2.6-.3-4.6-1.3-6-3-.9-1.1-1.4-2.5-1.5-4.1z"/><path d="M19.5 9.5c-2.6.3-4.6 1.3-6 3-.9 1.1-1.4 2.5-1.5 4.1 2.6-.3 4.6-1.3 6-3 .9-1.1 1.4-2.5 1.5-4.1z"/><path d="M5.5 19.5c1.9 1 4.1 1.5 6.5 1.5s4.6-.5 6.5-1.5"/></svg>
              </span>
              <span class="svc__name">Massaggi</span>
              <span class="svc__desc">rilassamento e cura del corpo</span>
            </a>
            <a class="svc" href={BOOKING} target="_blank" rel="noopener" aria-label="Viso e corpo Vagheggi — apri il calendario e prenota">
              <span class="svc__ico" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 19C5 10.2 10.2 5 19 5c0 8.8-5.2 14-14 14z"/><path d="M5 19c4.5-4.5 8-8 12-12"/></svg>
              </span>
              <span class="svc__name">Viso e corpo Vagheggi</span>
              <span class="svc__desc">trattamenti professionali, anche preparatori al laser</span>
            </a>
          </div>
          <div class="svcs-cta">
            <a class="btn" href={BOOKING} target="_blank" rel="noopener">Apri il calendario e prenota</a>
            <p class="cta-note">Si apre il calendario online del centro: scegli servizio, giorno e ora.</p>
          </div>
        </div>
      </section>

      <!-- 3 · METODO (cream + infografica soglia) -->
      <section class="sec sec--cream">
        <div class="container split">
          <div class="split__text">
            <h2>Partiamo piano e saliamo poco alla volta.</h2>
            <p>
              Ci fermiamo nel punto in cui <span class="hl">senti il laser ma non fa male</span>:
              la tua <em>soglia di comfort</em>.
            </p>
            <p>
              A seguirti c'è un'estetista qualificata, con formazione certificata
              sull'uso del laser. La cabina è a norma: se la porta si apre,
              <strong>il laser si ferma da solo</strong>.
            </p>
          </div>
          <div class="scale panel" aria-hidden="true">
            <div class="scale__track">
              <span class="scale__fill"></span>
              <span class="scale__marker">
                <span class="bfly"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 6c-1.1-2-3.4-3.1-5.6-2.7C4.3 3.7 2.8 5.4 2.7 7.5c-.1 2.2 1.5 3.8 3.6 4.5-1.5.8-2.4 2.2-2.2 3.8.2 1.6 1.6 2.7 3.2 2.6 1.9-.1 3.4-1.6 4.7-3.5 1.3 1.9 2.8 3.4 4.7 3.5 1.6.1 3-1 3.2-2.6.2-1.6-.7-3-2.2-3.8 2.1-.7 3.7-2.3 3.6-4.5-.1-2.1-1.6-3.8-3.7-4.2C15.4 2.9 13.1 4 12 6z"/></svg></span>
                <span class="scale__mlabel">la tua soglia</span>
              </span>
            </div>
            <div class="scale__ends">
              <span>potenza bassa<br /><small>non senti nulla</small></span>
              <span class="r">potenza fissa<br /><small>uguale per tutte</small></span>
            </div>
          </div>
        </div>
      </section>

      <!-- 4 · GENTLETEST (plum + box glass, CTA ghost) -->
      <section class="sec sec--plum sec--center">
        <div class="container narrow">
          <div class="glass">
            <h2>Prova il laser prima di comprarlo: il GentleTest è gratuito.</h2>
            <p>
              Proviamo insieme, zona per zona, e trovi la soglia adatta alla tua
              pelle. Esci sapendo esattamente cosa sente la pelle,
              <strong>senza aver comprato nulla</strong>.
            </p>
            <p>
              Se hai già provato il laser altrove e ti sei pentita, è il punto da
              cui ripartire.
            </p>
            <a class="btn-ghost" href="/gentletest/">Scopri come funziona il GentleTest</a>
          </div>
        </div>
      </section>

      <!-- 5 · FIDUCIA (peach-light, recensioni Facebook reali) -->
      <section class="sec sec--peach">
        <div class="container">
          <div class="narrow narrow--head">
            <h2>Le recensioni di chi è già venuta.</h2>
            <p class="sechead__sub">
              Cinque stelle sulla pagina Facebook di Gentle Beam: recensioni
              reali, con nome e parole delle clienti.
            </p>
          </div>
          <div class="reviews">
            <article class="review">
              <p class="review__stars" aria-label="5 stelle su 5">★★★★★</p>
              <p class="review__text">&ldquo;Laser eccellente e super professionale.&rdquo;</p>
              <p class="review__who"><strong>Monica A.</strong><span>Consiglia su Facebook</span></p>
            </article>
            <article class="review">
              <p class="review__stars" aria-label="5 stelle su 5">★★★★★</p>
              <p class="review__text">&ldquo;Davvero un'ottima esperienza. Ho visto risultati già dalla prima seduta.&rdquo;</p>
              <p class="review__who"><strong>Alisea S.</strong><span>Consiglia su Facebook</span></p>
            </article>
            <article class="review">
              <p class="review__stars" aria-label="5 stelle su 5">★★★★★</p>
              <p class="review__text">&ldquo;Davvero ottimo! Soddisfatta già dalla prima seduta.&rdquo;</p>
              <p class="review__who"><strong>Rossana C.</strong><span>Consiglia su Facebook</span></p>
            </article>
            <article class="review">
              <p class="review__stars" aria-label="5 stelle su 5">★★★★★</p>
              <p class="review__text">&ldquo;Risultati già dalla prima seduta. Risultati bellissimi, esperienza di lusso.&rdquo;</p>
              <p class="review__who"><strong>Chiara P.</strong><span>Consiglia su Facebook</span></p>
            </article>
          </div>
          <p class="reviews__src">Recensioni reali dalla pagina Facebook di Gentle Beam.</p>
        </div>
      </section>

      <!-- 6 · CONTATTI (cream, mappa + info + CTA) -->
      <section class="sec sec--cream" id="contatti">
        <div class="container">
          <div class="narrow narrow--head">
            <h2>Siamo in via Sciuti 109, a Palermo.</h2>
          </div>
          <div class="locate">
            <div class="locate__map">
              <iframe
                title="Gentle Beam su Google Maps"
                src="https://maps.google.com/maps?q=Via+Giuseppe+Sciuti+109,+90144+Palermo+PA,+Italy&t=&z=16&ie=UTF8&iwloc=&output=embed"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
            </div>
            <div class="locate__info">
              <p><span class="locate__lbl">Indirizzo</span><br />Via Giuseppe Sciuti 109, 90144 Palermo</p>
              <p><span class="locate__lbl">Orari</span><br />Aperti dal lunedì al venerdì: 8:00-13:00 e 14:00-18:00. Sabato e domenica chiusi.</p>
              <p>
                <span class="locate__lbl">Contatti</span><br />
                Tel: <a href="tel:+393923038077">+39 392 303 8077</a><br />
                Email: <a href="mailto:info@gentlebeam.it">info@gentlebeam.it</a>
              </p>
              <a class="btn" href={BOOKING} target="_blank" rel="noopener">Prenota un appuntamento</a>
              <p class="cta-note cta-note--left">Si apre il calendario online del centro: scegli servizio, giorno e ora.</p>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container narrow">
        <p class="footer__about">
          Gentle Beam, centro di epilazione laser ed estetica in via Sciuti 109 a
          Palermo.
        </p>
        <p class="footer__d">
          I risultati possono variare da persona a persona. Trattamento di natura
          estetica, non sostituisce un consulto medico.
        </p>
        <p class="footer__legal">
          Pillitteri Gregorio — Via Giuseppe Sciuti 109, 90144 Palermo (PA) —
          P.IVA 06562460821 — REA PA-457433 — PEC pillitterigregorio@pec.it
        </p>
        <p class="footer__c">
          info@gentlebeam.it · <a href="tel:+393923038077">+39 392 303 8077</a> ·
          <a href="https://www.facebook.com/profile.php?id=100089144112601" target="_blank" rel="noopener">Facebook</a> ·
          <a href="https://www.instagram.com/gentlebeamitalia" target="_blank" rel="noopener">Instagram</a> ·
          <a href="/gentletest/privacy">Privacy Policy</a>
        </p>
      </div>
    </footer>

    <Analytics />

    <style is:global>
      :root {
        --peach-light: #fde6dc;
        --peach: #fbd2bc;
        --plum: #3c1f40;
        --plum-2: #2c1630;
        --plum-soft: #5a3460;
        --cream: #fbf7f4;
        --paper: #fff;
        --line: #ecdfd8;
        --max: 1080px;
        --narrow: 680px;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: "Libre Baskerville", Georgia, serif;
        font-size: 1.125rem;
        line-height: 1.7;
        color: var(--plum);
        background: var(--cream);
      }
      h1, h2 { font-family: "Josefin Sans", sans-serif; font-weight: 600; line-height: 1.16; margin: 0 0 1rem; }
      h2 { font-size: clamp(1.5rem, 3vw, 2rem); }
      h2 { font-weight: 700; }
      p { margin: 0 0 1rem; }
      em { font-style: italic; }
      strong { font-weight: 700; }
      .container { width: 100%; max-width: var(--max); margin: 0 auto; padding: 0 1.4rem; }
      .narrow { max-width: var(--narrow); margin: 0 auto; }
      .narrow--head { text-align: center; margin-bottom: 2.4rem; }
      .sechead__sub { font-size: 1.05rem; color: var(--plum-soft); max-width: 44rem; margin: 0 auto; }

      /* highlight DRD */
      .hl {
        display: inline-block;
        background: var(--peach);
        color: var(--plum);
        font-weight: 700;
        padding: 0.12em 0.45em;
        border-radius: 6px;
        line-height: 1.5;
      }

      /* SECTIONS — ritmo fondi LORI: plum / peach-light / cream alternati */
      .sec { padding: 4.5rem 0; }
      .sec--cream { background: var(--cream); }
      .sec--peach { background: var(--peach-light); }
      .sec--plum { background: var(--plum); color: var(--peach-light); }
      .sec--plum h2 { color: #fff; }
      .sec--center { text-align: center; }

      /* BUTTON — primaria su fondi chiari: plum pieno */
      .btn {
        display: inline-block; font-family: "Josefin Sans", sans-serif; font-weight: 700;
        font-size: 1.08rem; letter-spacing: 0.03em; text-decoration: none; cursor: pointer;
        padding: 1rem 2.4rem; border: none; border-radius: 999px;
        background: var(--plum); color: var(--cream);
        box-shadow: 0 10px 26px rgba(60,31,64,0.32); transition: transform .15s, box-shadow .15s;
        will-change: transform;
      }
      .btn:hover { transform: translateY(-2px); box-shadow: 0 14px 34px rgba(60,31,64,0.42); }
      /* primaria su plum: pill peach, unico blocco caldo pieno */
      .btn--peach { background: var(--peach); color: var(--plum); box-shadow: 0 10px 26px rgba(0,0,0,0.28); }
      .btn--peach:hover { box-shadow: 0 14px 34px rgba(0,0,0,0.36); }
      /* ghost GentleTest: bordo 2px, trasparente, niente ombra */
      .btn-ghost {
        display: inline-block; font-family: "Josefin Sans", sans-serif; font-weight: 700;
        font-size: 1.02rem; letter-spacing: 0.03em; text-decoration: none;
        padding: 0.85rem 1.9rem; border: 2px solid var(--peach); border-radius: 999px;
        background: transparent; color: var(--peach-light);
        transition: background .15s, color .15s;
      }
      .btn-ghost:hover { background: var(--peach); color: var(--plum); }

      /* micro-rassicurazione sotto ogni CTA primaria */
      .cta-note {
        font-family: "Josefin Sans", sans-serif; font-size: 0.92rem;
        color: var(--plum-soft); margin: 0.9rem 0 0;
      }
      .cta-note--dark { color: var(--peach-light); opacity: .92; }
      .cta-note--left { margin-top: 0.7rem; }

      /* HERO */
      .hero { position: relative; background: var(--plum); color: var(--peach-light); padding: 4.2rem 0 4.6rem; overflow: hidden; }
      .hero__bg { position: absolute; inset: 0; background-size: cover; background-position: center 25%; z-index: 0; }
      .hero__wrap { position: relative; z-index: 1; }
      .hero__text { max-width: 36rem; }
      .hero h1 { font-size: clamp(2.3rem, 5.2vw, 2.85rem); color: #fff; margin-bottom: 1.1rem; }
      .hero__accent { display: block; font-family: "Libre Baskerville", serif; font-style: italic; font-weight: 700; color: var(--peach); margin-top: .3rem; }
      .hero__sub { font-size: 1.12rem; line-height: 1.55; max-width: 30rem; margin-bottom: 1.7rem; }

      /* SERVIZI — 6 card cliccabili */
      .svcs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.3rem; }
      .svc {
        display: block; background: var(--paper); color: var(--plum); text-decoration: none;
        border-radius: 16px; padding: 1.6rem 1.5rem;
        box-shadow: 0 10px 26px rgba(60,31,64,.10);
        transition: transform .22s ease, box-shadow .22s ease;
      }
      .svc:hover { transform: translateY(-5px); box-shadow: 0 20px 44px rgba(60,31,64,.16); }
      .svc__ico {
        display: inline-flex; width: 52px; height: 52px; align-items: center; justify-content: center;
        border-radius: 14px; background: var(--peach-light); color: var(--plum);
      }
      .svc__ico svg { width: 30px; height: 30px; }
      .svc__name { display: block; font-family: "Josefin Sans", sans-serif; font-weight: 700; font-size: 1.08rem; line-height: 1.25; margin: .9rem 0 .35rem; }
      .svc__desc { display: block; font-size: .92rem; line-height: 1.5; color: var(--plum-soft); }
      .svcs-cta { text-align: center; margin-top: 2.6rem; }

      /* SPLIT metodo (testo + infografica) */
      .split { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 2.6rem; align-items: center; }
      .panel {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 1.8rem 1.6rem;
        box-shadow: 0 14px 36px rgba(60, 31, 64, 0.08);
        transition: transform .22s ease, box-shadow .22s ease;
      }
      .panel:hover { transform: translateY(-5px); box-shadow: 0 20px 44px rgba(60, 31, 64, 0.14); }

      /* SCALE infografica (identica alla landing) */
      .scale__track {
        position: relative; height: 16px; border-radius: 999px;
        background: linear-gradient(90deg, var(--line), var(--peach) 65%, var(--plum-soft));
        margin: 2.4rem 0 .6rem;
      }
      .scale__fill { position: absolute; inset: 0; border-radius: 999px; }
      .scale__marker { position: absolute; left: 65%; top: 50%; transform: translate(-50%,-50%); text-align: center; }
      .scale__marker .bfly { display: block; color: var(--plum); }
      .scale__marker .bfly svg { width: 30px; height: 30px; }
      .scale__mlabel {
        position: absolute; left: 50%; transform: translateX(-50%); top: 30px; white-space: nowrap;
        font-family: "Josefin Sans", sans-serif; font-weight: 600; font-size: .875rem; color: var(--plum);
        background: var(--paper); border: 1px solid var(--line); padding: .15rem .5rem; border-radius: 999px;
      }
      .scale__ends { display: flex; justify-content: space-between; font-family: "Josefin Sans", sans-serif; font-size: .875rem; color: var(--plum-soft); margin-top: 1.6rem; }
      .scale__ends .r { text-align: right; }
      .scale__ends small { opacity: .75; font-size: 100%; }

      /* GLASS box GentleTest */
      .glass {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(251, 210, 188, 0.35);
        border-radius: 20px;
        padding: 2.6rem 2.2rem;
        backdrop-filter: blur(2px);
      }
      .glass h2 { margin-bottom: 1.2rem; }
      .glass p { max-width: 36rem; margin-left: auto; margin-right: auto; }
      .glass .btn-ghost { margin-top: .6rem; }

      /* REVIEWS (identiche alla landing, ombra tarata su fondo chiaro) */
      .reviews { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 1.2rem; }
      .review { background: var(--paper); color: var(--plum); border-radius: 16px; padding: 1.4rem 1.5rem; box-shadow: 0 10px 26px rgba(60,31,64,.12); }
      .review__stars { margin: 0 0 .55rem; color: #a8790a; font-size: 1.02rem; letter-spacing: .12em; line-height: 1; }
      .review__text { font-family: "Libre Baskerville", serif; font-style: italic; font-size: 1.05rem; line-height: 1.5; margin: 0 0 1rem; }
      .review__who { font-family: "Josefin Sans", sans-serif; margin: 0; }
      .review__who strong { display: block; color: var(--plum); font-size: .98rem; }
      .review__who span { color: var(--plum-soft); font-size: .875rem; }
      .reviews__src { text-align: center; font-size: .92rem; color: var(--plum-soft); margin: 1.4rem 0 0; }

      /* CONTATTI */
      .locate { display: grid; grid-template-columns: 1.2fr .8fr; gap: 1.8rem; align-items: stretch; }
      .locate__map { border-radius: 18px; overflow: hidden; box-shadow: 0 12px 30px rgba(60,31,64,.12); min-height: 320px; }
      .locate__map iframe { width: 100%; height: 100%; min-height: 320px; border: 0; display: block; }
      .locate__info { display: flex; flex-direction: column; justify-content: center; }
      .locate__info p { font-size: 1.02rem; margin: 0 0 1.1rem; }
      .locate__info a { color: var(--plum); }
      .locate__lbl { font-family: "Josefin Sans", sans-serif; font-weight: 700; font-size: .875rem; text-transform: uppercase; letter-spacing: .12em; color: var(--plum-soft); }
      .locate__info .btn { align-self: flex-start; margin-top: .4rem; color: var(--cream); }

      /* FOOTER */
      .footer { background: var(--plum-2); color: var(--peach-light); padding: 2.4rem 0; font-size: .92rem; line-height: 1.65; }
      .footer__about { font-family: "Josefin Sans", sans-serif; font-weight: 600; margin: 0 0 .8rem; }
      .footer__d { opacity: .8; margin: 0 0 .6rem; }
      .footer__legal { opacity: .68; font-size: .875rem; margin: 0 0 .8rem; }
      .footer__c { font-family: "Josefin Sans", sans-serif; margin: 0; }
      .footer a { color: var(--peach); }

      /* profondita': blob sfocati dietro alle sezioni chiare (come landing) */
      .sec--cream, .sec--peach { position: relative; overflow: hidden; }
      .sec--cream::before, .sec--peach::before {
        content: ""; position: absolute; width: 380px; height: 380px; border-radius: 50%;
        background: radial-gradient(circle, rgba(251,210,188,0.5), rgba(251,210,188,0));
        top: -140px; right: -120px; pointer-events: none; z-index: 0;
      }
      .sec--peach::before { background: radial-gradient(circle, rgba(255,255,255,0.55), rgba(255,255,255,0)); }
      .sec > .container { position: relative; z-index: 1; }

      /* reveal allo scroll (attivo solo con JS = classe .anim su <html>) */
      .anim .reveal { opacity: 0; transform: translateY(26px); transition: opacity .7s cubic-bezier(.2,.7,.2,1), transform .7s cubic-bezier(.2,.7,.2,1); }
      .anim .reveal.in { opacity: 1; transform: none; }
      .anim .scale .scale__marker { left: 6%; opacity: 0; transition: left 1.1s cubic-bezier(.2,.7,.2,1) .25s, opacity .5s ease .25s; }
      .anim .scale.in .scale__marker { left: 65%; opacity: 1; }
      @media (prefers-reduced-motion: reduce) {
        .anim .reveal, .anim .reveal.in { opacity: 1 !important; transform: none !important; transition: none !important; }
        .anim .scale .scale__marker { left: 65%; opacity: 1; transition: none; }
        .svc, .panel { transition: none; }
      }

      /* SITE HEADER — compresso 64px, logo 52px */
      .site-header {
        position: sticky; top: 0; z-index: 100;
        background: var(--cream);
        border-bottom: 1px solid rgba(60,31,64,.12);
        box-shadow: 0 2px 12px rgba(60,31,64,.08);
      }
      .site-header__inner {
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
        max-width: var(--max); margin: 0 auto; padding: 0 1.4rem;
        height: 64px;
      }
      .site-header__logo img { display: block; height: 52px; width: auto; }
      .site-header__nav {
        display: flex; align-items: center; gap: 1.6rem;
        list-style: none; margin: 0; padding: 0; flex: 1; justify-content: flex-end;
      }
      .site-header__nav a {
        font-family: "Josefin Sans", sans-serif; font-weight: 600; font-size: .92rem;
        color: var(--plum); text-decoration: none; white-space: nowrap;
      }
      .site-header__nav a:hover { text-decoration: underline; }
      .site-header__cta {
        flex-shrink: 0;
        font-family: "Josefin Sans", sans-serif; font-weight: 700; font-size: .92rem;
        background: var(--plum); color: var(--cream);
        padding: .55rem 1.2rem; border-radius: .45rem; text-decoration: none; white-space: nowrap;
      }
      .site-header__cta:hover { background: var(--plum-soft); }

      /* RESPONSIVE */
      @media (max-width: 860px) {
        .split, .locate { grid-template-columns: 1fr; gap: 1.8rem; }
        .split__text { max-width: var(--narrow); }
        .svcs { grid-template-columns: repeat(2, 1fr); gap: .9rem; }
        .svc { padding: 1.2rem 1.05rem; }
        .svc__ico { width: 44px; height: 44px; border-radius: 12px; }
        .svc__ico svg { width: 26px; height: 26px; }
        .svc__name { font-size: 1rem; }
        .hero__bg { background-position: center 18%; }
      }
      @media (max-width: 640px) {
        /* su mobile resta solo il link GentleTest: e' la porta della lettrice nuova */
        .site-header__nav { display: flex; flex: 1; justify-content: flex-end; }
        .site-header__nav li { display: none; }
        .site-header__nav li.nav-keep { display: block; }
        .site-header__inner { gap: .8rem; }
      }
      @media (max-width: 600px) {
        body { font-size: 1rem; }
        .sec { padding: 3rem 0; }
        .hero { padding: 2.4rem 0 2.8rem; }
        .svc__desc { font-size: .875rem; }
        .glass { padding: 2rem 1.4rem; }
        .btn { padding: .95rem 2rem; }
      }
    </style>

    <script is:inline>
      (() => {
        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        document.documentElement.classList.add('anim');
        const sel = 'h1, h2, .hero__sub, .hero .btn--peach, .svc, .review, .scale, .split__text, .glass, .locate__map, .locate__info';
        const els = Array.from(document.querySelectorAll(sel));
        els.forEach((el) => {
          el.classList.add('reveal');
          const sibs = el.parentElement ? Array.from(el.parentElement.children).filter(c => c.classList.contains('reveal')) : [];
          const i = sibs.indexOf(el);
          if (i > 0) el.style.transitionDelay = Math.min(i, 4) * 0.09 + 's';
        });
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting || e.boundingClientRect.top < 0) { e.target.classList.add('in'); io.unobserve(e.target); }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>

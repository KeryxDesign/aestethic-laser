# GentleTest — sta in /gentletest sul server Hostinger
ErrorDocument 404 /gentletest/404.html

# La chiave Kit e' letta solo server-side da lead.php: mai servirla via HTTP
<Files "kit_key.php">
  Require all denied
</Files>

# /gentletest/prenota -> calendario SumUp Booking (302: se il cliente cambia
# sistema di prenotazione basta aggiornare questa riga, QR e link restano validi)
Redirect 302 /gentletest/prenota https://www.sumupbookings.com/gentlebeam
